rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /alumnos/{alumnoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid in firestore.get(/databases/(default)/documents/alumnos/$(alumnoId)).data.apoderados
        || firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin'
      );
    }
  }
}
