rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated()
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == role;
    }

    function isAdmin()     { return hasRole('admin');     }
    function isDocente()   { return hasRole('docente');   }
    function isApoderado() { return hasRole('apoderado'); }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isDocenteOfCurso(cursoId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/cursos/$(cursoId)).data.docentes;
    }

    function isApoderadoOfAlumno(alumnoId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/alumnos/$(alumnoId)).data.apoderados;
    }

    // ─── DENY ALL by default ─────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }

    // ─── usuarios ─────────────────────────────────────────────────────────────

    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── alumnos ──────────────────────────────────────────────────────────────

    match /alumnos/{alumnoId} {
      allow read: if isApoderadoOfAlumno(alumnoId) || isDocente() || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isApoderadoOfAlumno(alumnoId) || isAdmin();
    }

    // ─── cursos ───────────────────────────────────────────────────────────────

    match /cursos/{cursoId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // ─── eventos ──────────────────────────────────────────────────────────────

    match /eventos/{eventoId} {
      allow read: if isAuthenticated();
      allow create: if isDocenteOfCurso(request.resource.data.cursoId) || isAdmin();
      allow update: if isDocenteOfCurso(resource.data.cursoId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── notas ────────────────────────────────────────────────────────────────

    match /notas/{notaId} {
      allow read: if isApoderadoOfAlumno(resource.data.alumnoId)
                  || isDocenteOfCurso(resource.data.cursoId)
                  || isAdmin();
      allow create: if isDocenteOfCurso(request.resource.data.cursoId) || isAdmin();
      allow update: if isDocenteOfCurso(resource.data.cursoId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── asistencia ───────────────────────────────────────────────────────────

    match /asistencia/{registroId} {
      allow read: if isApoderadoOfAlumno(resource.data.alumnoId)
                  || isDocenteOfCurso(resource.data.cursoId)
                  || isAdmin();
      allow create: if isDocenteOfCurso(request.resource.data.cursoId) || isAdmin();
      allow update: if isApoderadoOfAlumno(resource.data.alumnoId)
                    || isDocenteOfCurso(resource.data.cursoId)
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── mensajes ─────────────────────────────────────────────────────────────

    match /mensajes/{mensajeId} {
      allow read: if isAuthenticated()
                  && (resource.data.de == request.auth.uid
                      || resource.data.para == request.auth.uid)
                  || isAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.de == request.auth.uid;
      allow update: if resource.data.para == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── avisos ───────────────────────────────────────────────────────────────

    match /avisos/{avisoId} {
      allow read: if isAuthenticated()
                  && (request.auth.uid in resource.data.destinatarios
                      || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (isAuthenticated()
                        && request.auth.uid in resource.data.destinatarios
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leidoPor']));
    }

    // ─── documentos ───────────────────────────────────────────────────────────

    match /documentos/{docId} {
      allow read: if isApoderadoOfAlumno(resource.data.alumnoId) || isAdmin();
      allow create: if isApoderado() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    // ─── configuracion ────────────────────────────────────────────────────────
    match /configuracion/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── horarios ─────────────────────────────────────────────────────────────
    match /horarios/{cursoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
