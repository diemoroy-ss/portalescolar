# Variables de entorno — Colegio Montahue Portal Escolar
# Copiar este archivo como .env y completar con tus credenciales reales
# NUNCA subir el archivo .env al repositorio

# ─── Firebase ─────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=1:your-app-id:web:your-hash
VITE_FIREBASE_MEASUREMENT_ID=G-YOUR-MEASUREMENT-ID

# ─── FCM (Push Notifications) ─────────────────────────────────────────────────
# Obtenido en Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=your-vapid-key-here

# ─── App Config ───────────────────────────────────────────────────────────────
VITE_APP_NAME=Portal Escolar Colegio Montahue
VITE_APP_URL=https://portal.montahue.cl
VITE_SESSION_TIMEOUT_MINUTES=30
